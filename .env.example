# ── Backend ───────────────────────────────────────────────────────────────────

# Database (defaults to SQLite — no change needed for local dev)
DATABASE_URL=sqlite:///./dossier.db

# JWT signing key — generate with: openssl rand -hex 32
SECRET_KEY=change-me

# Email used by seed.py to create the local dev user
DEV_USER_EMAIL=dev@example.com

# Google OAuth — create credentials at console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# Where the backend redirects after OAuth (leave blank to return JSON instead)
FRONTEND_URL=http://localhost:3000

# Email address that can access GET /admin/stats (leave blank to disable)
ADMIN_EMAIL=

# ── Frontend (ui/) ────────────────────────────────────────────────────────────

# Backend URL used by Next.js — set in .env.local inside ui/ for local dev,
# or as a Vercel environment variable in production
NEXT_PUBLIC_API_URL=http://localhost:8000
