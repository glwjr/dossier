# ── Backend ───────────────────────────────────────────────────────────────────

# Database (defaults to SQLite — no change needed for local dev)
DATABASE_URL=sqlite:///./dossier.db

# JWT signing key — generate with: openssl rand -hex 32 (required; startup rejects this default in production)
SECRET_KEY=change-me

# Email used by seed.py to create the local dev user
DEV_USER_EMAIL=dev@example.com

# Google OAuth — create credentials at console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# Where the backend redirects after OAuth (leave blank to return JSON instead).
# The JWT is set as an HttpOnly cookie either way.
FRONTEND_URL=http://localhost:3000

# Domain for the auth cookie. In production set to the shared parent of the API
# and app subdomains (e.g. .dossiertool.com) so the API-set cookie reaches the
# frontend middleware. Leave blank in local dev (host-only cookie on localhost).
COOKIE_DOMAIN=

# Email address that can access GET /admin/stats (leave blank to disable)
ADMIN_EMAIL=

# No-signup demo login (GET /auth/demo). Leave DEMO_TEMPLATE_EMAIL blank to
# disable. Seed the template account first: python seed.py demo@dossiertool.com
DEMO_TEMPLATE_EMAIL=
# Demo accounts are garbage-collected past this age; keep >= the token lifetime.
DEMO_TTL_HOURS=168
# Hard ceiling on live demo accounts (oldest evicted past this).
DEMO_MAX_USERS=500
# Per-IP cap on demo logins per minute (0 disables rate limiting).
DEMO_RATE_LIMIT_PER_MINUTE=10

# Error tracking (leave blank to disable Sentry). Set to your Sentry DSN in prod.
SENTRY_DSN=
# Fraction of requests traced for performance (0 = errors only).
SENTRY_TRACES_SAMPLE_RATE=0.0

# ── Frontend (ui/) ────────────────────────────────────────────────────────────

# Backend URL used by Next.js — set in .env.local inside ui/ for local dev,
# or as a Vercel environment variable in production
NEXT_PUBLIC_API_URL=http://localhost:8000

# Marketing/landing site (Google + demo CTAs). Unauthenticated app visitors are
# redirected here. Defaults to https://dossiertool.com; override for local dev.
NEXT_PUBLIC_MARKETING_URL=https://dossiertool.com
