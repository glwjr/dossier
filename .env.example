# Google OAuth credentials — required for /auth/login and /auth/callback
# Create a project at https://console.cloud.google.com, enable the Google+ API,
# and add http://localhost:8000/auth/callback as an authorized redirect URI.
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT signing key — change this in any non-local environment
SECRET_KEY=dev-secret-key-change-in-production

# Set to your frontend URL so the OAuth callback redirects back to the UI
# FRONTEND_URL=https://your-app.vercel.app

# Optional overrides (defaults shown)
# DATABASE_URL=sqlite:///./dossier.db
# GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback
# DEV_USER_EMAIL=dev@example.com
# ACCESS_TOKEN_EXPIRE_MINUTES=10080
